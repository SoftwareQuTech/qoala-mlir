# Object build statements for EXECUTABLE target lir-translate


#############################################
# Order-only phony target for lir-translate

build cmake_object_order_depends_target_lir-translate: phony || cmake_object_order_depends_target_HirToLir cmake_object_order_depends_target_HirTransforms cmake_object_order_depends_target_LirToSplitLir cmake_object_order_depends_target_LirToText cmake_object_order_depends_target_LirTransforms cmake_object_order_depends_target_MLIRCLir cmake_object_order_depends_target_MLIRHir cmake_object_order_depends_target_MLIRLir cmake_object_order_depends_target_MLIRQLir

build tools/lir-translate/CMakeFiles/lir-translate.dir/lir-translate.cpp.o: CXX_COMPILER__lir-translate ../tools/lir-translate/lir-translate.cpp || cmake_object_order_depends_target_lir-translate
  DEFINES = -DGTEST_HAS_RTTI=0 -D_DEBUG -D__STDC_CONSTANT_MACROS -D__STDC_FORMAT_MACROS -D__STDC_LIMIT_MACROS
  DEP_FILE = tools/lir-translate/CMakeFiles/lir-translate.dir/lir-translate.cpp.o.d
  FLAGS = -fPIC -fno-semantic-interposition -fvisibility-inlines-hidden -Werror=date-time -Wall -Wextra -Wno-unused-parameter -Wwrite-strings -Wcast-qual -Wno-missing-field-initializers -Wimplicit-fallthrough -Wno-class-memaccess -Wno-redundant-move -Wno-pessimizing-move -Wno-noexcept-type -Wdelete-non-virtual-dtor -Wsuggest-override -Wno-comment -Wmisleading-indentation -fdiagnostics-color -ffunction-sections -fdata-sections   -D_DEBUG -D__STDC_CONSTANT_MACROS -D__STDC_FORMAT_MACROS -D__STDC_LIMIT_MACROS  -fno-exceptions -fno-rtti -fno-exceptions -fno-rtti -UNDEBUG -std=gnu++14
  INCLUDES = -I../include -Iinclude
  OBJECT_DIR = tools/lir-translate/CMakeFiles/lir-translate.dir
  OBJECT_FILE_DIR = tools/lir-translate/CMakeFiles/lir-translate.dir
  TARGET_COMPILE_PDB = tools/lir-translate/CMakeFiles/lir-translate.dir/
  TARGET_PDB = bin/lir-translate.pdb


# =============================================================================
# Link build statements for EXECUTABLE target lir-translate


#############################################
